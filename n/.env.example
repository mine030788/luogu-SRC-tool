# ========== OpenAI 兼容平台（必填） ==========
# 模型调用所需的 API Key（**部署前请到对应平台撤销并重发**，本文件已脱敏）
OPENAI_API_KEY=sk-REPLACE-WITH-YOUR-REAL-KEY
# 可选：管理员子 key（暂未使用）
OPENAI_ADMIN_KEY=

# 兼容 OpenAI 接口的 Base URL（不填默认 https://api.openai.com/v1）
OPENAI_BASE_URL=https://api.openai.com/v1

# 模型名（不同平台不同，例如 deepseek-chat / gpt-4o-mini / qwen-max ...）
OPENAI_MODEL_NAME=gpt-4o-mini

# 若服务器缺中文字体，是否启动时自动下载（默认 1）
LUOGU_REPORT_AUTO_FONT_DOWNLOAD=1

# ========== 管理后台（部署前必须改！） ==========
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE-ME-TO-A-STRONG-PASSWORD
# 终端执行：openssl rand -hex 32
ADMIN_SESSION_SECRET=CHANGE-ME-TO-A-LONG-RANDOM-HEX-STRING
