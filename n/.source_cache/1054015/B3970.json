{"time": 30, "memory": 680, "problem": {"pid": "B3970", "title": "[语言月赛 202405] 数字取模", "difficulty": 1, "type": "B"}, "sourceCodeLength": 184, "submitTime": 1718456963, "language": 28, "user": {"uid": 1054015, "name": "OP03_2", "avatar": "https://cdn.luogu.com.cn/upload/usericon/1054015.png", "slogan": "zorr noob lv250||https://atcoder.jp/users/cmq2014", "isAdmin": false, "isBanned": false, "color": "Red", "ccfLevel": 4, "xcpcLevel": 0, "background": "https://cdn.luogu.com.cn/upload/image_hosting/q28gw6j3.png"}, "id": 162275601, "status": 12, "enableO2": true, "score": 100, "detail": {"compileResult": {"success": true, "opt2": false}, "judgeResult": {"finishedCaseCount": 10, "status": 0, "time": 0, "memory": 0, "score": 0}, "version": 400}, "sourceCode": "#include<bits/stdc++.h>\r\nusing namespace std;\r\nint main(void){\r\n\tint x,y,ans=0,i=0;\r\n\tcin>>x>>y;\r\n\twhile(x){\r\n\t\tans+=(x%10%y)*pow(10,i),x/=10,i++;\r\n\t}\r\n\tcout<<ans;\r\n\treturn false;\r\n}\r\n", "_detail_requested": true, "_cached_at": "2026-06-05 20:19:01"}