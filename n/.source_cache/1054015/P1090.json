{"time": 49, "memory": 628, "problem": {"pid": "P1090", "title": "[NOIP 2004 提高组] 合并果子", "difficulty": 3, "type": "P"}, "contest": {"id": 258507, "name": "数据结构", "startTime": 1752539400, "endTime": 1752657099}, "sourceCodeLength": 321, "submitTime": 1752539492, "language": 28, "user": {"uid": 1054015, "name": "OP03_2", "avatar": "https://cdn.luogu.com.cn/upload/usericon/1054015.png", "slogan": "zorr noob lv250||https://atcoder.jp/users/cmq2014", "isAdmin": false, "isBanned": false, "color": "Red", "ccfLevel": 4, "xcpcLevel": 0, "background": "https://cdn.luogu.com.cn/upload/image_hosting/q28gw6j3.png"}, "id": 224412698, "status": 12, "enableO2": true, "score": 100, "detail": {"compileResult": {"success": true, "opt2": false}, "judgeResult": {"finishedCaseCount": 10, "status": 0, "time": 0, "memory": 0, "score": 0}, "version": 400}, "sourceCode": "#include<bits/stdc++.h>\nusing namespace std;\nint main(void)\n{\n\tpriority_queue<int,vector<int>,greater<int> > q;\n\tint n,x,sum=0,t1,t2;\n\tcin>>n;\n\tfor(int i=0;i<n;i++){\n\t\tcin>>x;\n\t\tq.push(x);\n\t}\n\twhile(q.size()>1){\n\t\tt1=q.top();\n\t\tq.pop();\n\t\tt2=q.top();\n\t\tq.pop();\n\t\tsum+=t1+t2;\n\t\tq.push(t1+t2);\n\t}\n\tcout<<sum;\n\treturn 0;\n}\n", "_detail_requested": true, "_cached_at": "2026-06-05 17:27:26"}